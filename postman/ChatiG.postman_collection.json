            },
            "description": "Strukturali xohishlardan tayyor system prompt generatsiya qiladi (guardrail'lar majburan qo'shiladi). OpenAI krediti kerak."
          }
        },
        {
          "name": "Prompt · Test",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/ai/prompt/test", "host": ["{{base_url}}"], "path": ["api", "v1", "ai", "prompt", "test"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Siz Texno Do'kon sotuvchisisiz. Xushmuomala bo'ling.\",\n  \"message\": \"Salom, RTX 4060 bormi?\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Settings · Get",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/ai/settings", "host": ["{{base_url}}"], "path": ["api", "v1", "ai", "settings"] }
          }
        },
        {
          "name": "Settings · Save",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/ai/settings", "host": ["{{base_url}}"], "path": ["api", "v1", "ai", "settings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"system_prompt\": \"Siz Texno Do'kon sotuvchisisiz...\",\n  \"mode\": \"suggest\",\n  \"working_hours\": { \"from\": \"09:00\", \"to\": \"21:00\" }\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Webhooks (Instagram)",
      "item": [
        {
          "name": "Verify (GET handshake)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/webhooks/instagram?hub.mode=subscribe&hub.verify_token={{instagram_verify_token}}&hub.challenge=12345",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "webhooks", "instagram"],
              "query": [
                { "key": "hub.mode", "value": "subscribe" },
                { "key": "hub.verify_token", "value": "{{instagram_verify_token}}" },
                { "key": "hub.challenge", "value": "12345" }
              ]
            },
            "description": "Meta handshake. To'g'ri token bo'lsa hub.challenge qaytadi."
          }
        },
        {
          "name": "Incoming DM (POST, auto-signed)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// X-Hub-Signature-256 ni body + app_secret dan avtomatik hisoblaydi",
                  "const secret = pm.collectionVariables.get('instagram_app_secret') || '';",
                  "const body = pm.request.body && pm.request.body.raw ? pm.request.body.raw : '';",
                  "const sig = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'X-Hub-Signature-256', value: 'sha256=' + sig });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/webhooks/instagram", "host": ["{{base_url}}"], "path": ["api", "v1", "webhooks", "instagram"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"object\": \"instagram\",\n  \"entry\": [\n    {\n      \"id\": \"IG_BUSINESS_ACCOUNT_ID\",\n      \"messaging\": [\n        {\n          \"sender\": { \"id\": \"customer-99\" },\n          \"recipient\": { \"id\": \"IG_BUSINESS_ACCOUNT_ID\" },\n          \"message\": { \"mid\": \"mid-1\", \"text\": \"Salom, RTX 4060 bormi?\" }\n        }\n      ]\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "instagram_app_secret variable'ni to'ldiring va entry.id ni ulangan kanal external_id'siga moslang. Imzo pre-request skriptida avtomatik hisoblanadi."
          }
        }
      ]
    }
  ]
}
