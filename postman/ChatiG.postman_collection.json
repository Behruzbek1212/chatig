      "item": [
        {
          "name": "Prompt · Generate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/ai/prompt/generate", "host": ["{{base_url}}"], "path": ["api", "v1", "ai", "prompt", "generate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tone\": \"dostona\",\n  \"out_of_stock_behavior\": \"Tovar tugagan bo'lsa, o'xshashini taklif qil\",\n  \"haggling_policy\": \"Chegirma bermaymiz, lekin xushmuomala bo'l\",\n  \"after_hours_behavior\": \"Ish vaqtidan tashqarida ertalab javob berishni ayt\",\n  \"extra_notes\": \"Yetkazib berish bor\"\n}",
