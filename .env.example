APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=chatig
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Telescope (local dev only; disabled in tests via phpunit.xml) ---
TELESCOPE_ENABLED=true
# TELESCOPE_PATH=telescope
# TELESCOPE_ALLOWED_PHONES=+998901234567
# TELESCOPE_ALLOWED_EMAILS=admin@example.com

# --- ChatiG ---
SPA_URL=http://localhost:5173

SMS_DRIVER=log
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

LLM_DRIVER=openai
OPENAI_API_KEY=
OPENAI_MODEL_SALES=gpt-4o
OPENAI_MODEL_INTENT=gpt-4o-mini
OPENAI_MODEL_PROMPT=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Local Instagram OAuth/webhooks via ngrok (scripts/ngrok-dev.ps1)
NGROK_AUTHTOKEN=

INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Must exactly match a redirect URI in your Meta app (HTTPS in production; use ngrok for local OAuth).
INSTAGRAM_REDIRECT_URI=http://localhost:8080/api/v1/integrations/instagram/callback
INSTAGRAM_GRAPH_VERSION=v23.0
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# --- Telegram (shared platform bot + catalog Mini App) ---
TELEGRAM_BOT_USERNAME=
TELEGRAM_MINI_APP_BOT_TOKEN=
TELEGRAM_MINI_APP_URL=http://localhost:5174
TELEGRAM_INIT_DATA_MAX_AGE=3600
